# EditorConfig -- https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4
max_line_length = 100

[*.{toml,yml,yaml,json}]
indent_size = 2

[*.{md,markdown}]
# Markdown uses trailing double-space for hard line breaks.
trim_trailing_whitespace = false

[*.{R,r,Rmd,Rd}]
indent_size = 2

# Generated/templated R-package files use tabs (Makevars) -- handled below.
[{Makefile,Makevars,Makevars.in,Makevars.win,Makevars.win.in}]
indent_style = tab
